# ──────────────────────────────────────────────
# Confluent Cloud
# ──────────────────────────────────────────────
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxxx.us-east-1.aws.confluent.cloud:9092
CONFLUENT_API_KEY=your_confluent_api_key
CONFLUENT_API_SECRET=your_confluent_api_secret
CONFLUENT_SCHEMA_REGISTRY_URL=https://psrc-xxxxxx.us-east-2.aws.confluent.cloud
CONFLUENT_SCHEMA_REGISTRY_API_KEY=your_sr_api_key
CONFLUENT_SCHEMA_REGISTRY_API_SECRET=your_sr_api_secret

# ──────────────────────────────────────────────
# AWS
# ──────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_GLUE_DATABASE=your_glue_database

# ──────────────────────────────────────────────
# Kafka producer routing (used by all producers)
# ──────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_API_KEY=your_kafka_api_key
KAFKA_API_SECRET=your_kafka_api_secret

TOPIC_ORDERS=orders
TOPIC_CLICKSTREAM=clickstream
TOPIC_PAYMENTS=payments
TOPIC_WEATHER=weather
TOPIC_DLQ=dead-letter-queue

# ──────────────────────────────────────────────
# Producer throughput / behaviour
# ──────────────────────────────────────────────
MALFORMED_RATE=0.05
ORDERS_EVENTS_PER_SECOND=2
CLICKSTREAM_EVENTS_PER_SECOND=5
PAYMENTS_EVENTS_PER_SECOND=1.5
WEATHER_POLL_INTERVAL_SECONDS=60

# ──────────────────────────────────────────────
# OpenWeatherMap
# ──────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key
OPENWEATHER_UNITS=metric

# ──────────────────────────────────────────────
# Apache Airflow
# ──────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost/airflow
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_key
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_HOME=/opt/airflow

# ──────────────────────────────────────────────
# dbt
# ──────────────────────────────────────────────
DBT_PROFILES_DIR=./dbt_project
DBT_TARGET=dev
DBT_SNOWFLAKE_ACCOUNT=your_snowflake_account
DBT_SNOWFLAKE_USER=your_snowflake_user
DBT_SNOWFLAKE_PASSWORD=your_snowflake_password
DBT_SNOWFLAKE_DATABASE=your_database
DBT_SNOWFLAKE_SCHEMA=your_schema
DBT_SNOWFLAKE_WAREHOUSE=your_warehouse
DBT_SNOWFLAKE_ROLE=your_role

# ──────────────────────────────────────────────
# Local Kafka (docker-compose)
# ──────────────────────────────────────────────
LOCAL_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
LOCAL_SCHEMA_REGISTRY_URL=http://localhost:8081
